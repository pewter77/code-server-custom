{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "LinuxServer images use version-X.X.X format",
      "versioning": "regex:^(?<compatibility>version)-v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)[\\.-]*r?(?<build>\\d+)*-*r?(?<release>\\w+)*",
      "matchPackageNames": [
        "/linuxserver/"
      ]
    },
    {
      "groupName": "Mend: All Minor and Patch Releases",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    }
  ],
  "platformAutomerge": true,
  "ignoreTests": true
}
